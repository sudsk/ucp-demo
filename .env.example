# ── REQUIRED ──────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ── OPTIONAL: Stripe test mode ─────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
# Must be a sk_test_... key — no real money moves
STRIPE_TEST_SECRET_KEY=sk_test_your_stripe_test_key_here

# ── OPTIONAL: Google Sheets product data ──────────────────────
# If not set, uses hardcoded fallback product list
# GOOGLE_SHEET_ID=your_sheet_id_here
# GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# ── OPTIONAL: Gemini model override ───────────────────────────
GEMINI_MODEL=gemini-3-flash
